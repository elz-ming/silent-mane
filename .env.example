# Absolute or relative path to the docs directory on the local filesystem.
# Used by the API routes in local/dev mode.
# On Vercel, leave unset and configure BlobStorage instead (see src/lib/storage/BlobStorage.ts).
SILENT_MANE_DOCS=./docs

# Vercel Blob — required for cloud storage (Sprint 001/002).
# Get this from your Vercel project dashboard → Storage → Blob.
BLOB_READ_WRITE_TOKEN=
