# Absolute or relative path to the docs directory on the local filesystem.
# Used by the API routes in local/dev mode.
# On Vercel, leave unset and configure BlobStorage instead (see src/lib/storage/BlobStorage.ts).
EMDEE_DOCS=./docs

# Vercel Blob — required for cloud storage (Sprint 001/002).
# Get this from your Vercel project dashboard → Storage → Blob.
BLOB_READ_WRITE_TOKEN=

# Supabase — whatelz-supabase project (https://tnjujbkpepchhgyqwmtb.supabase.co)
# Get these from: Supabase dashboard → Settings → API
# Clerk — get from clerk.com dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase — emdee-supabase project
NEXT_PUBLIC_SUPABASE_URL=https://lzibjuqtfptogzwmxbcu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
